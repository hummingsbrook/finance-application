# ─────────────────────────────────────────────────────────────────────────────
# ChurchFinance Pro — TEST Environment
# ─────────────────────────────────────────────────────────────────────────────
# FIXED: C-1 — test-only non-sensitive values. Never reuse production secrets
# here. These values exist solely so the Jest + supertest suite can boot the
# Express app, sign/verify JWTs, and connect to a local test database.
# ─────────────────────────────────────────────────────────────────────────────

# Test database. Point at a throwaway local DB (MySQL or SQLite file).
# Examples:
#   MySQL:  "mysql://root:@localhost:3306/churchfinance_test"
#   SQLite: "file:./prisma/test.db"  (requires copying schema.sqlite.prisma
#           over schema.prisma first — see TEST_README.md)
DATABASE_URL="mysql://root:@localhost:3306/churchfinance_test"

# Test-only JWT secret. NOT for production. Generates valid but throwaway
# signatures so the auth controllers can sign/verify during integration tests.
JWT_SECRET="test-jwt-secret-not-for-production-use"

# FIXED: C-3 — JWT_RESET_SECRET removed; reset flow now uses single-use
# crypto tokens stored as hashes on the User record.

# ── Recommended ───────────────────────────────────────────────────────────────
NODE_ENV="test"
# FIXED: M-2 — default JWT expiry shortened to 8h
JWT_EXPIRES_IN="8h"
PORT=3001
CLIENT_URL="http://localhost:5173"

# ── Optional — disabled in tests ──────────────────────────────────────────────
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM_EMAIL=
SMTP_FROM_NAME=ChurchFinance Pro

MPESA_ENVIRONMENT=sandbox
MPESA_CONSUMER_KEY=
MPESA_CONSUMER_SECRET=

GEMINI_API_KEY=
