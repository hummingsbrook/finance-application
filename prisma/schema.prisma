generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// ─── ENUMS ───────────────────────────────────────────────────────────────────

enum Role {
  PARTNER
  MANAGER
  SUPER_ADMIN
}

enum PaymentMethod {
  CASH
  MPESA
  BANK_TRANSFER
}

enum PaymentStatus {
  PENDING
  CONFIRMED
  REJECTED
  FAILED
}

enum ExpenseCategory {
  SALARIES
  UTILITIES
  MAINTENANCE
  EVENTS
  TRANSPORT
  SUPPLIES
  MISCELLANEOUS
}

enum AuditAction {
  CREATE
  UPDATE
  DELETE
  LOGIN
  LOGOUT
  STATUS_CHANGE
}

// ─── USER ────────────────────────────────────────────────────────────────────

model User {
  id              String   @id @default(uuid())
  email           String   @unique
  passwordHash    String
  firstName       String
  lastName        String
  role            Role     @default(PARTNER)
  phone           String?
  isActive        Boolean  @default(true)
  lastLoginAt     DateTime?
  // FIXED: C-3 — single-use password reset token (stored as hash) + expiry
  passwordResetToken  String?   @unique
  passwordResetExpiry DateTime?
  // FIXED: H-2 — account lockout after repeated failed logins
  failedLoginAttempts Int      @default(0)
  lockedUntil         DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  // Relations
  tithes              Tithe[]
  offerings           Offering[]
  recordedExpenses    Expense[]              @relation("ExpenseRecorder")
  approvedExpenses    Expense[]              @relation("ExpenseApprover")
  payments            Payment[]
  auditLogs           AuditLog[]
  createdHarambees    Harambee[]              @relation("HarambeeCreator")
  harambeeContributions HarambeeContribution[] @relation("HarambeeContributor")
  confirmedPayments   Payment[]              @relation("PaymentConfirmer")

  @@map("users")
}

// ─── TITHE ───────────────────────────────────────────────────────────────────

model Tithe {
  id              String         @id @default(uuid())
  contributorName String
  amount          Decimal        @db.Decimal(12, 2)
  date            DateTime
  paymentMethod   PaymentMethod  @default(CASH)
  mpesaReceiptNo  String?
  bankName        String?
  chequeNumber    String?
  idNumber        String?
  notes           String?
  status          PaymentStatus  @default(CONFIRMED)
  recordedBy      String
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  recordedByUser  User           @relation(fields: [recordedBy], references: [id])

  @@index([date])
  @@index([status])
  @@index([date, status])
  @@map("tithes")
}

// ─── OFFERING ────────────────────────────────────────────────────────────────

model Offering {
  id              String         @id @default(uuid())
  contributorName String
  amount          Decimal        @db.Decimal(12, 2)
  date            DateTime
  serviceType     String         // "Sunday Main", "Wednesday Bible Study", etc.
  paymentMethod   PaymentMethod  @default(CASH)
  mpesaReceiptNo  String?
  bankName        String?
  chequeNumber    String?
  idNumber        String?
  notes           String?
  status          PaymentStatus  @default(CONFIRMED)
  recordedBy      String
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  recordedByUser  User           @relation(fields: [recordedBy], references: [id])

  @@index([date])
  @@index([status])
  @@index([date, status])
  @@map("offerings")
}

// ─── EXPENSE ─────────────────────────────────────────────────────────────────

model Expense {
  id              String          @id @default(uuid())
  description     String
  amount          Decimal         @db.Decimal(12, 2)
  date            DateTime
  category        ExpenseCategory
  paymentMethod   PaymentMethod   @default(CASH)
  recipientName   String?
  mpesaReceiptNo  String?
  bankName        String?
  accountNo       String?
  idNumber        String?
  notes           String?
  status          PaymentStatus   @default(CONFIRMED)
  recordedBy      String
  approvedBy      String?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  recordedByUser  User            @relation("ExpenseRecorder", fields: [recordedBy], references: [id])
  approvedByUser  User?           @relation("ExpenseApprover", fields: [approvedBy], references: [id])

  @@index([date])
  @@index([status])
  @@index([date, status])
  @@map("expenses")
}

// ─── HARAMBEE ────────────────────────────────────────────────────────────────

model Harambee {
  id              String         @id @default(uuid())
  title           String
  description     String?
  targetAmount    Decimal        @db.Decimal(14, 2)
  currentAmount   Decimal        @default(0) @db.Decimal(14, 2)
  startDate       DateTime
  endDate         DateTime?
  status          HarambeeStatus @default(ACTIVE)
  createdBy       String
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  contributions       HarambeeContribution[]
  payments           Payment[]
  createdByUser     User               @relation("HarambeeCreator", fields: [createdBy], references: [id])

  @@map("harambees")
}

model HarambeeContribution {
  id              String         @id @default(uuid())
  harambeeId      String
  contributorName String
  amount          Decimal        @db.Decimal(12, 2)
  date            DateTime
  paymentMethod   PaymentMethod  @default(CASH)
  mpesaReceiptNo  String?
  notes           String?
  recordedBy      String
  createdAt       DateTime       @default(now())

  harambee        Harambee       @relation(fields: [harambeeId], references: [id], onDelete: Cascade)
  recordedByUser  User           @relation("HarambeeContributor", fields: [recordedBy], references: [id])

  @@map("harambee_contributions")
}

// ─── PAYMENT (Partner-initiated) ─────────────────────────────────────────────

model Payment {
  id              String         @id @default(uuid())
  userId          String
  amount          Decimal        @db.Decimal(12, 2)
  paymentType     String         // "TITHE", "OFFERING", "HARAMBEE"
  harambeeId      String?
  paymentMethod   PaymentMethod  @default(MPESA)
  mpesaReceiptNo  String?
  phoneNumber     String?
  status          PaymentStatus  @default(PENDING)
  rejectionReason String?
  confirmedBy     String?
  confirmedAt     DateTime?
  checkoutRequestId String?      @unique
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  user            User           @relation(fields: [userId], references: [id])
  harambee        Harambee?      @relation(fields: [harambeeId], references: [id])
  confirmedByUser User?          @relation("PaymentConfirmer", fields: [confirmedBy], references: [id])

  @@map("payments")
}

enum ServiceStatus {
  SCHEDULED
  INCOMPLETE
  COMPLETED
}

enum HarambeeStatus {
  ACTIVE
  COMPLETED
  CANCELLED
}

// ─── CHURCH SERVICE ──────────────────────────────────────────────────────────

model ChurchService {
  id          String        @id @default(uuid())
  name        String
  dayOfWeek   String        // "Sunday", "Wednesday", etc.
  time        String        // "09:00", "18:30"
  serviceDate DateTime?     // specific date of this occurrence (nullable)
  topic       String?       // sermon topic / theme
  speaker     String?       // preacher name
  programmer  String?       // service MC / programme coordinator
  leadMinistrant String?    // spiritual lead / lead ministrant
  reader      String?       // Bible reader
  notes       String?       // general notes
  status      ServiceStatus @default(SCHEDULED)
  isActive    Boolean       @default(true)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  @@map("church_services")
}

// ─── AUDIT LOG ───────────────────────────────────────────────────────────────

model AuditLog {
  id              String       @id @default(uuid())
  userId          String
  action          AuditAction
  module          String       // "tithes", "offerings", etc.
  recordId        String?
  details         String?      @db.Text
  ipAddress       String?
  createdAt       DateTime     @default(now())

  user            User         @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([module])
  @@index([createdAt])
  @@map("audit_logs")
}

