// Partners module removed — Payment model and PARTNER role deleted.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// ─── ENUMS ───────────────────────────────────────────────────────────────────

enum Role {
  MANAGER
  SUPER_ADMIN
}

enum PaymentMethod {
  CASH
  MPESA
  BANK_TRANSFER
}

enum PaymentStatus {
  PENDING
  CONFIRMED
  REJECTED
  FAILED
}

enum ExpenseCategory {
  SALARIES
  UTILITIES
  MAINTENANCE
  EVENTS
  TRANSPORT
  SUPPLIES
  MISCELLANEOUS
}

enum SalaryType {
  PASTOR
  CARETAKER
  SECURITY_OFFICER
}

enum EventContributionType {
  MONEY
  IN_KIND
}

enum InKindCategory {
  FOOD
  CLOTHES
  SUPPLIES
  OTHERS
}

enum ChurchEventType {
  NEW_YEAR
  GOOD_FRIDAY
  EASTER_SUNDAY
  EASTER_MONDAY
  CHRISTMAS
  BOXING_DAY
  THANKSGIVING_SUNDAY
  CHURCH_ANNIVERSARY
  HARVEST_FESTIVAL
  CUSTOM
}

enum AuditAction {
  CREATE
  UPDATE
  DELETE
  LOGIN
  LOGOUT
  STATUS_CHANGE
}

enum HarambeeStatus {
  ACTIVE
  COMPLETED
  CANCELLED
}

enum ServiceStatus {
  SCHEDULED
  INCOMPLETE
  COMPLETED
}

// ─── USER ────────────────────────────────────────────────────────────────────

model User {
  id              String    @id @default(uuid())
  email           String    @unique
  passwordHash    String
  firstName       String
  lastName        String
  phone           String?
  role            Role      @default(MANAGER)
  isActive        Boolean   @default(true)
  lastLogin       DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  // Relations
  tithes              Tithe[]
  offerings           Offering[]
  expenses            Expense[]
  harambees           Harambee[]
  harambeeContributions HarambeeContribution[]
  auditLogs           AuditLog[]
  churchServices      ChurchService[]
  eventContributions  EventContribution[]     @relation("EventContributionRecorder")

  @@map("users")
}

// ─── TITHE ───────────────────────────────────────────────────────────────────

model Tithe {
  id              String        @id @default(uuid())
  contributorName String
  amount          Decimal       @db.Decimal(12, 2)
  date            DateTime
  paymentMethod   PaymentMethod @default(CASH)
  mpesaReceiptNo  String?
  bankName        String?
  chequeNumber    String?
  idNumber        String?
  notes           String?
  status          PaymentStatus @default(CONFIRMED)
  recordedBy      String
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  recordedByUser  User          @relation(fields: [recordedBy], references: [id])

  @@map("tithes")
}

// ─── OFFERING ─────────────────────────────────────────────────────────────────

model Offering {
  id              String        @id @default(uuid())
  contributorName String
  amount          Decimal       @db.Decimal(12, 2)
  date            DateTime
  serviceType     String        // "Sunday Main" | "Sunday School"
  paymentMethod   PaymentMethod @default(CASH)
  mpesaReceiptNo  String?
  bankName        String?
  chequeNumber    String?
  idNumber        String?
  notes           String?
  status          PaymentStatus @default(CONFIRMED)
  recordedBy      String
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  recordedByUser  User          @relation(fields: [recordedBy], references: [id])

  @@map("offerings")
}

// ─── EXPENSE ─────────────────────────────────────────────────────────────────

model Expense {
  id              String          @id @default(uuid())
  description     String
  amount          Decimal         @db.Decimal(12, 2)
  date            DateTime
  category        ExpenseCategory
  salaryType      SalaryType?
  paymentMethod   PaymentMethod   @default(CASH)
  recipientName   String?
  mpesaReceiptNo  String?
  bankName        String?
  accountNo       String?
  idNumber        String?
  notes           String?
  status          PaymentStatus   @default(CONFIRMED)
  recordedBy      String
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  recordedByUser  User            @relation(fields: [recordedBy], references: [id])

  @@map("expenses")
}

// ─── HARAMBEE ────────────────────────────────────────────────────────────────

model Harambee {
  id              String         @id @default(uuid())
  title           String
  description     String?
  targetAmount    Decimal        @db.Decimal(14, 2)
  currentAmount   Decimal        @default(0) @db.Decimal(14, 2)
  deadline        DateTime?
  status          HarambeeStatus @default(ACTIVE)
  createdBy       String
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  createdByUser   User           @relation(fields: [createdBy], references: [id])
  contributions   HarambeeContribution[]

  @@map("harambees")
}

model HarambeeContribution {
  id              String        @id @default(uuid())
  harambeeId      String
  contributorName String
  amount          Decimal       @db.Decimal(12, 2)
  date            DateTime
  paymentMethod   PaymentMethod @default(CASH)
  mpesaReceiptNo  String?
  bankName        String?
  chequeNumber    String?
  notes           String?
  recordedBy      String
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  harambee        Harambee      @relation(fields: [harambeeId], references: [id])
  recordedByUser  User          @relation(fields: [recordedBy], references: [id])

  @@map("harambee_contributions")
}

// ─── EVENT CONTRIBUTION ─────────────────────────────────────────────────────

model EventContribution {
  id                  String                   @id @default(uuid())

  contributorName     String

  contributionType    EventContributionType

  amount              Decimal?                 @db.Decimal(12, 2)
  paymentMethod       PaymentMethod?
  mpesaReceiptNo      String?
  bankName            String?
  accountNo           String?
  idNumber            String?

  inKindCategory      InKindCategory?
  inKindDescription   String?                  @db.Text
  inKindOtherType     String?

  eventType           ChurchEventType          @default(CUSTOM)
  eventName           String
  eventDate           DateTime

  programmeTeam       String?                  @db.Text

  notes               String?
  recordedBy          String
  createdAt           DateTime                 @default(now())
  updatedAt           DateTime                 @updatedAt

  recordedByUser      User                     @relation("EventContributionRecorder", fields: [recordedBy], references: [id])

  @@index([eventDate])
  @@index([eventType])
  @@index([contributionType])
  @@map("event_contributions")
}

// ─── CHURCH SERVICE ──────────────────────────────────────────────────────────

model ChurchService {
  id            String        @id @default(uuid())
  name          String
  dayOfWeek     String        // "Sunday", "Wednesday", etc.
  time          String        // "09:00", "18:30"
  serviceDate   DateTime?     // specific date of this occurrence (nullable)
  topic         String?       // sermon topic / theme
  speaker       String?       // preacher name
  programmer    String?       // service MC / programme coordinator
  leadMinistrant String?      // spiritual lead / lead ministrant
  reader        String?       // Bible reader
  notes         String?       // general notes
  status        ServiceStatus @default(SCHEDULED)
  isActive      Boolean       @default(true)
  createdBy     String
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  createdByUser User          @relation(fields: [createdBy], references: [id])

  @@map("church_services")
}

// ─── AUDIT LOG ───────────────────────────────────────────────────────────────

model AuditLog {
  id          String      @id @default(uuid())
  userId      String
  action      AuditAction
  module      String       // "tithes", "offerings", etc.
  recordId    String?
  details     String?      @db.Text
  ipAddress   String?
  createdAt   DateTime     @default(now())
  user        User         @relation(fields: [userId], references: [id])

  @@map("audit_logs")
}
